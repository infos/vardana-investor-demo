# To set up Redis: Vercel dashboard → Storage → Upstash (Serverless Redis)
# Vercel auto-injects UPSTASH_REDIS_REST_URL and UPSTASH_REDIS_REST_TOKEN once connected
# Without Redis, visits still log to Vercel Function Logs — search [DEMO_VISIT]

# ─── Demo Route Token ─────────────────────────────────────────────
# Random alphanumeric string that gates /demo access.
# The demo hub is served at /demo/<token> instead of /demo.
# Generate one: python3 -c "import random,string; print(''.join(random.choices(string.ascii_lowercase+string.digits,k=12)))"
# Must also be set in Vercel → Settings → Environment Variables (all envs).
VITE_DEMO_TOKEN=

# ─── Demo Analytics ───────────────────────────────────────────────
# Set this manually in Vercel → Settings → Environment Variables
# Used to access the analytics dashboard at /admin?secret=<value>
ANALYTICS_SECRET=

# Upstash Redis (connected via Vercel Storage → Upstash)
# Vercel auto-injects these when the KV store is connected:
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Legacy Vercel KV env var names (also supported as fallback):
KV_REST_API_URL=
KV_REST_API_TOKEN=

# ─── Voice pipeline (EC2 Pipecat backend) ─────────────────────────
# Used by api/session-start and api/session-end. Server-side only —
# never prefixed with VITE_, so the value never reaches the browser.
#
# Production: https://voice.vardana.ai
# Local backend testing: http://localhost:8765 (with the FastAPI
#   server from the vardana-voice repo running locally)
VOICE_BACKEND_URL=https://voice.vardana.ai

# Bearer token the backend's verify_session_token() expects in
# Authorization: Bearer <token>. Read off the EC2 .env file
# (VOICE_SESSION_TOKEN field). Must be set in Vercel for any env
# where /voice-test should work.
VOICE_SESSION_TOKEN=
