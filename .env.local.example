# To set up KV: Vercel dashboard → your project → Storage → Add KV store
# Vercel auto-injects KV_REST_API_URL and KV_REST_API_TOKEN once connected
# Without KV, visits still log to Vercel Function Logs — search [DEMO_VISIT]

# Demo Analytics
ANALYTICS_SECRET=           # Random string — used to access /admin/analytics
KV_REST_API_URL=            # From Vercel KV store (Storage tab in Vercel dashboard)
KV_REST_API_TOKEN=          # From Vercel KV store
